<h6 class="form-section-header"><?php $this->_('Apnscp.tab_stats.info_title');?></h6>
<div class="mb-3">
    <table class="table">
        <thead>
            <tr>
                <th style="width: 50%;"><?php $this->_('Apnscp.tab_stats.info_heading.field'); ?></th>
                <th><?php $this->_('Apnscp.tab_stats.info_heading.value'); ?></th>
            </tr>
        </thead>
        <tbody>
            <?php
            $keys = ['disk', 'bandwidth'];
            foreach ($keys as $i => $key) {
                if (isset($stats->{$key})) {
            ?>
