                <td><?php $this->_('Apnscp.tab_stats.info.' . $key); ?></td>
                <td><?php echo $this->Html->safe(round($stats->{$key}['used'], 2)) . ' MB /' . $this->Html->safe($stats->{$key}['total'] == '-1' ? '∞' : round($stats->{$key}['total'], 2) . ' MB'); ?></td>
            </tr>
            <?php
                }
            }
            ?>
        </tbody>
    </table>
</div>